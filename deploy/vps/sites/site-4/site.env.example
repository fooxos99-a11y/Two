NODE_ENV=production
APP_PORT=3004
PORT=3004

# Site identity
WHATSAPP_INSTANCE_SLUG=site-4
WHATSAPP_CLIENT_ID=habib-site-4
SUPABASE_PROJECT_REF=replace_with_your_site_4_supabase_project_ref

# Use the same Supabase project and keys as the matching Vercel app.
NEXT_PUBLIC_SUPABASE_URL=https://replace_with_your_site_4_project_ref.supabase.co
SUPABASE_URL=https://replace_with_your_site_4_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_your_site_4_anon_or_publishable_key
SUPABASE_ANON_KEY=replace_with_your_site_4_anon_or_publishable_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_your_site_4_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_site_4_service_role_key

# Keep these aligned with the app if you also use the VPS app mode later.
AUTH_SESSION_SECRET=replace_with_your_auth_session_secret
SESSION_SECRET=replace_with_your_session_secret
NEXTAUTH_SECRET=replace_with_your_nextauth_secret
CRON_SECRET=replace_with_your_cron_secret

# WhatsApp worker isolation for site-4
WHATSAPP_AUTH_DIR=/var/www/habib/shared/site-4/.wwebjs_auth
WHATSAPP_STATUS_FILE_PATH=/var/www/habib/shared/site-4/whatsapp-status.json
WHATSAPP_QR_IMAGE_PATH=/var/www/habib/shared/site-4/whatsapp-qr.png
WHATSAPP_COMMAND_FILE_PATH=/var/www/habib/shared/site-4/whatsapp-command.json
WHATSAPP_LOCK_FILE_PATH=/var/www/habib/shared/site-4/whatsapp-worker.lock

# These values must match the Vercel app exactly.
WHATSAPP_WORKER_STATE_SETTING_ID=whatsapp_worker_state
WHATSAPP_WORKER_COMMAND_SETTING_ID=whatsapp_worker_command
WHATSAPP_QUEUE_TABLE=whatsapp_queue
WHATSAPP_HISTORY_TABLE=whatsapp_messages
WHATSAPP_REPLIES_TABLE=whatsapp_replies
WHATSAPP_MIN_DELAY_MS=5000
WHATSAPP_MAX_DELAY_MS=12000
WHATSAPP_BURST_SIZE=20
WHATSAPP_BURST_PAUSE_MIN_MS=10000
WHATSAPP_BURST_PAUSE_MAX_MS=20000
WHATSAPP_INCOMING_SYNC_INTERVAL_MS=30000
WHATSAPP_INCOMING_SYNC_CHAT_LIMIT=30
WHATSAPP_INCOMING_SYNC_MESSAGE_LIMIT=8
WHATSAPP_QUEUE_POLL_INTERVAL_MS=5000
WHATSAPP_HEARTBEAT_INTERVAL_MS=15000
WHATSAPP_CONNECTION_CHECK_INTERVAL_MS=10000

# Optional. Leave empty unless auto-detection fails on the VPS.
PUPPETEER_EXECUTABLE_PATH=

WEB_PUSH_SUBJECT=
WEB_PUSH_PRIVATE_KEY=
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PUBLIC_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
META_APP_SECRET=