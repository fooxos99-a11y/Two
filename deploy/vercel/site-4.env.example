NODE_ENV=production

# Use the exact same Supabase project and secrets already configured in Vercel.
SUPABASE_PROJECT_REF=replace_with_your_site_4_supabase_project_ref
NEXT_PUBLIC_SUPABASE_URL=https://replace_with_your_site_4_project_ref.supabase.co
SUPABASE_URL=https://replace_with_your_site_4_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_your_site_4_anon_or_publishable_key
SUPABASE_ANON_KEY=replace_with_your_site_4_anon_or_publishable_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_your_site_4_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_site_4_service_role_key

# Keep these secrets identical between Vercel and the VPS worker if both use the same app auth flows.
AUTH_SESSION_SECRET=replace_with_your_auth_session_secret
SESSION_SECRET=replace_with_your_session_secret
NEXTAUTH_SECRET=replace_with_your_nextauth_secret
CRON_SECRET=replace_with_your_cron_secret

# These values must match the VPS worker exactly.
WHATSAPP_WORKER_STATE_SETTING_ID=whatsapp_worker_state
WHATSAPP_WORKER_COMMAND_SETTING_ID=whatsapp_worker_command
WHATSAPP_QUEUE_TABLE=whatsapp_queue
WHATSAPP_HISTORY_TABLE=whatsapp_messages
WHATSAPP_REPLIES_TABLE=whatsapp_replies

WEB_PUSH_SUBJECT=
WEB_PUSH_PRIVATE_KEY=
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PUBLIC_KEY=

# Optional if you later switch some flows to WhatsApp Cloud API.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
META_APP_SECRET=